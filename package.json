{
  "name": "codex",
  "version": "1.1.0",
  "description": "CODEX - Cyberpunk Music Discovery",
  "author": "FRAGUAR",
  "companyName": "FRAGUAR",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:win:nsis": "electron-builder --win nsis",
    "build:win:portable": "electron-builder --win portable",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.codex.music",
    "productName": "CODEX",
    "copyright": "Copyright © 2024 FRAGUAR",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CODEX",
      "uninstallDisplayName": "CODEX",
      "deleteAppDataOnUninstall": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "installerHeader": "public/installer-header.png",
      "installerSidebar": "public/installer-sidebar.bmp",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "music-metadata": "^7.14.0",
    "node-fetch": "^2.7.0",
    "slsk-client": "^1.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-installer-windows": "^3.0.0",
    "electron-packager": "^17.1.2",
    "sharp": "^0.34.5"
  }
}
